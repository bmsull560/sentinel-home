# ─── Required for local server boot ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
DATABASE_URL=mysql://user:password@localhost:3306/sentinel_home
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-characters

# ─── Required for OAuth sign-in flow ─────────────────────────────────────────
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# ─── Optional: skip OAuth for local UI testing ───────────────────────────────
# WARNING: never enable this in production
DEV_BYPASS_AUTH=false

# ─── Optional: client-side branding ──────────────────────────────────────────
VITE_APP_TITLE=Sentinel Home
VITE_APP_LOGO=https://placehold.co/128x128/E1E7EF/1F2937?text=Sentinel

# ─── Optional: Umami analytics ───────────────────────────────────────────────
# Sentinel Home uses Umami (privacy-first, cookie-free analytics) by default.
# Google Analytics is intentionally not used to align with the security/privacy
# positioning of the product.
#
# To enable traffic tracking in production:
# 1. Create an account at https://cloud.umami.is (or self-host Umami)
# 2. Add a site and copy your Website ID
# 3. Set the endpoint and website ID below
#
# If either value is left empty, the analytics script is not injected.
# Example:
# VITE_ANALYTICS_ENDPOINT=https://cloud.umami.is
# VITE_ANALYTICS_WEBSITE_ID=<your-umami-website-id>
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ─── Optional: Forge API for LLM and built-in integrations ───────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── Optional: NVD API key for higher rate limits during ingestion ───────────
NVD_API_KEY=

# ─── Optional: Redis for shared rate limiting (recommended for multi-instance) ─
# REDIS_URL=redis://localhost:6379

# ─── Optional: log level (fatal, error, warn, info, debug, trace) ────────────
# LOG_LEVEL=info
